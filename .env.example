# Socrates AI - Environment Configuration
# Copy this file to .env and add your API key

# OpenAI API Key (required for LLM-powered questions)
# Get your key from: https://platform.openai.com/api-keys
# Without this key, the system uses rule-based question templates
OPENAI_API_KEY=your_openai_api_key_here

# Debug Mode (optional)
# Set to 1 to enable verbose debug output
# SOCRATES_DEBUG=0
