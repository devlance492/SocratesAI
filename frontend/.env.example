# Socrates AI Frontend - Environment Configuration
# Copy this file to .env and fill in your values for local development.
# In Vercel, set these under Project Settings → Environment Variables.

# URL of the deployed FastAPI backend (no trailing slash).
# Example: https://your-backend.railway.app
# For local development, leave this unset or use http://localhost:8000
VITE_API_URL=http://localhost:8000
